## 五、状态管理（Pinia Store）

### `src/store/quiz.js`

```javascript
import { defineStore } from 'pinia';
import { questionBank } from '@/data/questions';
import { shuffleArray, generateOptionOrder } from '@/utils/shuffle';
import { saveState, loadState, clearState } from '@/utils/storage';

export const useQuizStore = defineStore('quiz', {
  state: () => ({
    questionBank: questionBank,
    shuffledQuestionIds: [],      // 随机题目ID序列
    optionOrders: {},              // 每题选项排列索引
    answers: {},                   // 用户答案 { questionId: type }
    currentIndex: 0,               // 当前题目的索引
    completed: false
  }),

  getters: {
    // 当前题目对象
    currentQuestion(state) {
      if (state.currentIndex >= state.shuffledQuestionIds.length) return null;
      const qId = state.shuffledQuestionIds[state.currentIndex];
      return state.questionBank.find(q => q.id === qId);
    },

    // 当前题目的随机排列选项
    currentOptions(state) {
      const question = this.currentQuestion;
      if (!question) return [];
      const order = state.optionOrders[question.id] || [0, 1, 2, 3];
      return order.map(i => question.options[i]);
    },

    // 进度百分比
    progress(state) {
      return `${state.currentIndex + 1} / ${state.shuffledQuestionIds.length}`;
    },

    // 计算结果
    results(state) {
      const counts = { D: 0, I: 0, S: 0, C: 0 };
      Object.values(state.answers).forEach(type => {
        if (counts.hasOwnProperty(type)) {
          counts[type]++;
        }
      });
      return counts;
    }
  },

  actions: {
    /**
     * 初始化测评
     * 尝试从localStorage恢复，若无则创建新的随机序列
     */
    initQuiz() {
      const saved = loadState();
      if (saved && !saved.completed) {
        // 恢复之前的进度
        this.shuffledQuestionIds = saved.shuffledQuestionIds;
        this.optionOrders = saved.optionOrders;
        this.answers = saved.answers;
        this.currentIndex = saved.currentIndex;
        this.completed = false;
      } else {
        // 创建新的随机序列
        this.createNewSession();
      }
    },

    /**
     * 创建新的测评会话
     */
    createNewSession() {
      // 1. 随机排列题目
      const allIds = this.questionBank.map(q => q.id);
      this.shuffledQuestionIds = shuffleArray(allIds);

      // 2. 为每道题生成随机选项排列
      this.optionOrders = {};
      this.shuffledQuestionIds.forEach(id => {
        this.optionOrders[id] = generateOptionOrder(4);
      });

      // 3. 重置答案和进度
      this.answers = {};
      this.currentIndex = 0;
      this.completed = false;

      // 4. 持久化
      this.persist();
    },

    /**
     * 提交当前题目的答案
     * @param {string} type - 选择的DISC类型字母
     */
    submitAnswer(type) {
      const qId = this.shuffledQuestionIds[this.currentIndex];
      this.answers[qId] = type;
      this.currentIndex++;

      // 检查是否全部完成
      if (this.currentIndex >= this.shuffledQuestionIds.length) {
        this.completed = true;
      }

      this.persist();
    },

    /**
     * 将当前状态持久化到localStorage
     */
    persist() {
      saveState({
        shuffledQuestionIds: this.shuffledQuestionIds,
        optionOrders: this.optionOrders,
        answers: this.answers,
        currentIndex: this.currentIndex,
        completed: this.completed
      });
    },

    /**
     * 重置测评（清除所有数据）
     */
    resetQuiz() {
      clearState();
      this.createNewSession();
    }
  }
});
```

